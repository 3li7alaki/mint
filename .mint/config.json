{
  "stack": "none",
  "packageManager": "none",
  "gates": {
    "lint": false,
    "types": false,
    "tests": false
  },
  "reviewers": {
    "spec": { "enabled": true, "model": "opus" },
    "quality": { "enabled": true, "model": "sonnet" },
    "security": false,
    "conventions": { "enabled": true, "model": "haiku" },
    "tests": false,
    "business": { "enabled": true, "model": "opus" },
    "performance": false
  },
  "conventions": {
    "docs": [
      "docs/conventions.md",
      "CONTRIBUTING.md"
    ]
  },
  "business": {
    "docs": [
      "docs/architecture.md"
    ]
  },
  "isolation": {
    "plan": "worktree",
    "ship": "worktree",
    "quick": "branch"
  },
  "definitionOfDone": {
    "gatesPassing": true,
    "specReviewPassed": true,
    "stage2ReviewsPassed": true,
    "screenshotReminder": "ui-changes"
  },
  "documenters": [
    {
      "path": "README.md",
      "trigger": "on-task-complete",
      "description": "Public-facing project documentation — install, pipeline, agents, config",
      "mode": "update"
    }
  ],
  "plugins": []
}
