#!/usr/bin/env bash
# SessionStart hook for mint plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read the using-mint skill content
using_mint_content=$(cat "${PLUGIN_ROOT}/skills/using-mint/SKILL.md" 2>&1 || echo "Error reading using-mint skill")

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_mint_escaped=$(escape_for_json "$using_mint_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have mint.\n\n**Below is the full content of your 'mint:using-mint' skill. For the full orchestrator, use the 'Skill' tool to invoke 'mint':**\n\n${using_mint_escaped}\n</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
